---
interface Props {
  t: (key: string) => string
}

const { t } = Astro.props

const features = [
  {
    icon: '🤖',
    title: 'features.ai.title',
    desc: 'features.ai.desc',
  },
  {
    icon: '🔍',
    title: 'features.search.title',
    desc: 'features.search.desc',
  },
  {
    icon: '📚',
    title: 'features.formats.title',
    desc: 'features.formats.desc',
  },
  {
    icon: '📝',
    title: 'features.notes.title',
    desc: 'features.notes.desc',
  },
  {
    icon: '🧠',
    title: 'features.providers.title',
    desc: 'features.providers.desc',
  },
  {
    icon: '📊',
    title: 'features.stats.title',
    desc: 'features.stats.desc',
  },
]
---

<section id="features" class="py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        {t('features.title')}
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        {t('features.subtitle')}
      </p>
    </div>
    
    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <div class="group rounded-xl border border-border bg-card p-6 shadow-sm transition-all hover:border-primary/50 hover:shadow-md">
          <div class="mb-4 text-4xl">
            {feature.icon}
          </div>
          <h3 class="text-lg font-semibold">
            {t(feature.title)}
          </h3>
          <p class="mt-2 text-muted-foreground">
            {t(feature.desc)}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
