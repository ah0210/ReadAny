---
interface Props {
  t: (key: string) => string
}

const { t } = Astro.props
---

<section class="relative overflow-hidden pt-32 pb-20">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary/5 via-transparent to-transparent"></div>
  
  <div class="mx-auto max-w-6xl px-4 text-center">
    <h1 class="text-4xl font-bold tracking-tight sm:text-6xl">
      {t('hero.title')}
    </h1>
    
    <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
      {t('hero.subtitle')}
    </p>
    
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#download"
        class="inline-flex h-12 items-center justify-center rounded-lg bg-primary px-8 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
      >
        {t('hero.download')}
      </a>
      <a
        href="#features"
        class="inline-flex h-12 items-center justify-center rounded-lg border border-border bg-background px-8 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
      >
        {t('hero.learn')}
      </a>
    </div>
    
    <p class="mt-6 text-sm text-muted-foreground">
      {t('hero.platforms')}
    </p>
    
    <div class="relative mx-auto mt-16 max-w-4xl">
      <div class="aspect-video overflow-hidden rounded-xl border border-border bg-card shadow-2xl">
        <div class="flex h-full items-center justify-center bg-muted/50">
          <p class="text-muted-foreground">📸 Screenshot Coming Soon</p>
        </div>
      </div>
      
      <div class="absolute -bottom-4 left-1/2 h-24 w-1/2 -translate-x-1/2 rounded-full bg-primary/20 blur-3xl"></div>
    </div>
  </div>
</section>
